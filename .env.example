# Environment Variables — Copy this to .env.local and fill in the values
# DO NOT commit .env.local to Git

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Get these from your Neon dashboard → Project → Connection Details
# Select "Prisma" from the dropdown to get the correct format

# Pooled connection (used by Vercel serverless functions)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Your Vercel URL (set AFTER first deployment — copy from Vercel dashboard)
NEXTAUTH_URL="https://your-app-name.vercel.app"

# ── Optional: Admin seed credentials ─────────────────────────────────────────
# Used when running: npm run db:seed
ADMIN_EMAIL="admin@yourgamingcafe.com"
ADMIN_PASSWORD="YourStrongPassword123!"
