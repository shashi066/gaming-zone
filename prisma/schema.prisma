// Prisma schema for Gaming Cafe Booking App
// Production: PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("USER")   // "USER" | "ADMIN"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@map("users")
}

model Station {
  id          String   @id @default(cuid())
  name        String
  description String
  specs       String
  hourlyRate  Float
  imageUrl    String?
  isActive    Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@map("stations")
}

model Booking {
  id               String   @id @default(cuid())
  userId           String?
  stationId        String
  date             String   // YYYY-MM-DD
  startTime        String   // HH:MM
  endTime          String   // HH:MM
  duration         Int      // hours
  totalPrice       Float
  status           String   @default("PENDING")   // "PENDING" | "CONFIRMED" | "CANCELLED" | "COMPLETED"
  bookingType      String   @default("ONLINE")    // "ONLINE" | "OFFLINE"
  customerName     String?
  customerPhone    String?
  paymentStatus    String   @default("UNPAID")    // "UNPAID" | "PENDING" | "PAID"
  razorpayOrderId  String?
  razorpayPaymentId String?
  extraControllers Int      @default(0)
  controllerCharge Float    @default(0)
  notes            String?
  adminComment     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  updatedAt DateTime @updatedAt

  @@map("settings")
}
