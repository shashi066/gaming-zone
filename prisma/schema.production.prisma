// Production schema — PostgreSQL (Neon via Vercel)
// Used by Vercel build: prisma generate --schema=prisma/schema.production.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("USER")   // "USER" | "ADMIN"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings   Booking[]
  passes     UserPass[]
  dailySpins UserDailySpin[]

  @@map("users")
}

model Station {
  id          String   @id @default(cuid())
  name        String
  description String
  specs       String
  hourlyRate  Float
  minDuration Float    @default(1)
  hasControllers  Boolean  @default(true)
  imageUrl    String?
  isActive    Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@map("stations")
}

model Booking {
  id                String   @id @default(cuid())
  userId            String?
  stationId         String
  date              String
  startTime         String
  endTime           String
  duration          Float
  totalPrice        Float
  status            String   @default("PENDING")
  bookingType       String   @default("ONLINE")
  customerName      String?
  customerPhone     String?
  paymentStatus     String   @default("UNPAID")
  razorpayOrderId   String?
  razorpayPaymentId String?
  extraControllers  Int      @default(0)
  controllerCharge  Float    @default(0)
  notes             String?
  adminComment      String?
  userPassId        String?
  passHoursDeducted Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User?     @relation(fields: [userId],     references: [id], onDelete: SetNull)
  station  Station   @relation(fields: [stationId],  references: [id], onDelete: Cascade)
  userPass UserPass? @relation(fields: [userPassId], references: [id], onDelete: SetNull)

  @@map("bookings")
}

model UserPass {
  id          String   @id @default(cuid())
  userId      String
  passType    String
  totalHours  Int
  usedHours   Float    @default(0)
  price       Int
  status      String   @default("ACTIVE")
  purchasedAt DateTime @default(now())
  expiresAt   DateTime

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("user_passes")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model LootItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  weight      Int
  enabled     Boolean  @default(true)
  rarity      String?  @default("COMMON")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spins UserDailySpin[]

  @@map("loot_items")
}

model UserDailySpin {
  id         String    @id @default(cuid())
  userId     String
  lootItemId String?
  spinDate   String
  attempts   Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId],     references: [id], onDelete: Cascade)
  lootItem LootItem? @relation(fields: [lootItemId], references: [id], onDelete: SetNull)

  @@unique([userId, spinDate])
  @@map("user_daily_spins")
}
